      "parameters": {
        "jsCode": "// Inicializa el estado del paginador\n// La query SOQL base viene de default_params.q\nconst baseQuery = $('Get SF Resources1').first().json.default_params?.q || '';\nconst LIMIT = 1000;\n\n// Si la query no tiene LIMIT, se lo agregamos\nconst queryWithLimit = baseQuery.toUpperCase().includes('LIMIT')\n  ? baseQuery\n  : `${baseQuery} LIMIT ${LIMIT} OFFSET 0`;\n\nreturn [{\n  json: {\n    // Estado del loop\n    offset: 0,\n    limit: LIMIT,\n    hasMore: true,\n    pageCount: 0,\n    totalFetched: 0,\n    // Datos que necesitan los nodos del loop\n    accessToken: $('Authenticate5').first().json.access_token,\n    instanceUrl: $('Authenticate5').first().json.instance_url,\n    baseQuery: baseQuery,\n    endpointPath: $('Get SF Resources1').first().json.endpoint_path,\n    jobId: $('FF Create Job1').first().json.job_id,\n    resource: $('Get SF Resources1').first().json.slug,\n    // Primera URL a usar\n    nextUrl: null,\n    currentQuery: queryWithLimit\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -720,
        3776
      ],
      "id": "2cfd6301-63f5-4c85-b915-69f4e99bd1d7",
      "name": "FF Init Paginator"
    },
    {
      "parameters": {
        "jsCode": "// Decide qué URL/query usar:\n// - Si hay nextUrl (de la respuesta anterior de SF) → usarla directamente\n// - Si no → construir con OFFSET\nconst state = $input.item.json;\n\nconst LIMIT = state.limit;\nconst offset = state.offset;\nconst baseQuery = state.baseQuery;\n\n// SF devuelve nextRecordsUrl cuando hay más páginas\nconst nextUrl = state.nextUrl;\n\nlet fetchUrl;\nlet useQuery = false;\n\nif (nextUrl) {\n  // SF ya nos da la URL directa para la siguiente página\n  fetchUrl = state.instanceUrl + nextUrl;\n  useQuery = false;\n} else {\n  // Primera página o fallback con OFFSET\n  const queryWithOffset = baseQuery.toUpperCase().includes('LIMIT')\n    ? baseQuery\n        .replace(/LIMIT\\s+\\d+/i, `LIMIT ${LIMIT}`)\n        .replace(/OFFSET\\s+\\d+/i, `OFFSET ${offset}`)\n    : `${baseQuery} LIMIT ${LIMIT} OFFSET ${offset}`;\n  \n  fetchUrl = state.instanceUrl + state.endpointPath;\n  useQuery = true;\n  state.currentQuery = queryWithOffset;\n}\n\nreturn [{\n  json: {\n    ...state,\n    fetchUrl,\n    useQuery\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -496,
        3776
      ],
      "id": "8466f883-4cd3-4b60-b319-abe2b4b2b3ea",
      "name": "FF Build Request"
    },
    {
      "parameters": {
        "jsCode": "// Procesa la respuesta de Salesforce y actualiza el estado\nconst state = $('FF Build Request').item.json;\nconst response = $input.item.json;\n\n// SF devuelve los registros en response.records\nconst records = response.records || [];\nconst totalSize = response.totalSize || 0;\nconst nextRecordsUrl = response.nextRecordsUrl || null;\n\n// IMPORTANTE: nextRecordsUrl es la fuente de verdad para saber si hay más páginas.\n// SF puede devolver done:true incluso en la primera página si el dataset es pequeño,\n// pero también puede devolver done:true junto con nextRecordsUrl en edge cases.\n// Siempre priorizamos nextRecordsUrl. Solo cuando no existe miramos response.done.\nconst hasMore = !!nextRecordsUrl || response.done === false;\n\nconst newTotalFetched = state.totalFetched + records.length;\nconst newPageCount = state.pageCount + 1;\nconst newOffset = state.offset + records.length;\n\nconsole.log(`Página ${newPageCount}: ${records.length} registros | Total: ${newTotalFetched}/${totalSize} | done: ${response.done} | nextUrl: ${nextRecordsUrl} | hasMore: ${hasMore}`);\n\nreturn [{\n  json: {\n    // Estado actualizado para la próxima iteración\n    offset: newOffset,\n    limit: state.limit,\n    hasMore: hasMore,\n    pageCount: newPageCount,\n    totalFetched: newTotalFetched,\n    totalSize: totalSize,\n    accessToken: state.accessToken,\n    instanceUrl: state.instanceUrl,\n    baseQuery: state.baseQuery,\n    endpointPath: state.endpointPath,\n    jobId: state.jobId,\n    resource: state.resource,\n    nextUrl: nextRecordsUrl,\n    // Registros de esta página para enviar al job\n    pageRecords: records,\n    currentPage: newPageCount\n  }\n}];"
      },
