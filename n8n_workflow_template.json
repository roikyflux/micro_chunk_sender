        "jsCode": "const body = $('Webhook1').item.json.body;\nconst provider = $('Get Provider5').item.json;\nconst resource = $('Get SF Resources1').item.json;\n\nif (!provider?.id) throw new Error(`Provider not found: ${body.app}`);\nif (!resource?.id) throw new Error(`Dataset '${body.dataset}' not found for provider '${body.app}'`);\n\nreturn {\n  baseUrl: provider.base_url,\n  endpointPath: resource.endpoint_path,\n  defaultParams: resource.default_params || {},\n  paginationConfig: resource.pagination_config || {},\n  responseMapping: resource.response_mapping || {},\n  authType: provider.auth_type,\n  authConfig: provider.auth_config || {},\n  providerSlug: provider.slug,\n  resourceSlug: resource.slug,\n  clientId: body.client_id,\n  clientSecret: body.client_secret\n};"
